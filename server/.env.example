# ──────────────────────────────────────────────
# Server Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── MongoDB Atlas ────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/om_muruga_olympia_fitness?retryWrites=true&w=majority


# ── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret

# ── Firebase Admin SDK ───────────────────────
# Path to your downloaded service-account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# ── Admin ────────────────────────────────────
ADMIN_EMAIL=your-admin-email@example.com
# Optional: multiple admin emails (comma-separated)
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# ── Client origin (CORS) ────────────────────
CLIENT_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════
# RAZORPAY PAYMENT GATEWAY — TEST MODE
# ═══════════════════════════════════════════════════════════════
# 
# TEST API KEY (Do not use in production)
# Key ID: rzp_test_SR9RWdRpVz3HUg
# Key Secret: tKQnkln88pA9tY3V7cdIhIMK
#
# These are test credentials provided by Razorpay.
# Replace with production keys when deploying to production.
# ═════════════════════════════════════════════════════════════════

# Razorpay API Credentials (Test Mode)
RAZORPAY_KEY_ID=rzp_test_SR9RWdRpVz3HUg
RAZORPAY_KEY_SECRET=tKQnkln88pA9tY3V7cdIhIMK

# Razorpay Webhook Secret (Generate after creating webhook in Razorpay Dashboard)
# For testing: Use any secure string. In production, copy from Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# Payment Configuration
RAZORPAY_PAYMENT_MODE=test

# ─── Feature Flags ─────────────────────────────
PAYMENT_GATEWAY_ENABLED=true

# ─── Attendance Alerts ─────────────────────────
# Minutes after which an active in-gym session is flagged
# as a possible missed checkout in admin/user UI.
LONG_SESSION_ALERT_MINUTES=240
